{
  "name": "dietoken",
  "version": "0.1.0",
  "description": "Audite contexto de agentes de IA e corte desperdício de tokens.",
  "type": "module",
  "bin": {
    "dietoken": "./dist/cli.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ThomasTonho/dietoken.git"
  },
  "homepage": "https://github.com/ThomasTonho/dietoken#readme",
  "bugs": {
    "url": "https://github.com/ThomasTonho/dietoken/issues"
  },
  "files": [
    "dist",
    "README.md",
    "README.pt-BR.md",
    "docs"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "bundle": "esbuild src/cli.ts --bundle --platform=node --format=cjs --outfile=dist/dietoken.cjs && node scripts/add-shebang.mjs",
    "test": "npm run build && node --test tests/*.test.mjs",
    "check": "npm run build && npm test"
  },
  "keywords": [
    "ai-agents",
    "cli",
    "claude-code",
    "codex",
    "context-engineering",
    "developer-tools",
    "llm",
    "prompt-engineering",
    "token-optimization",
    "tokens",
    "typescript"
  ],
  "author": "ThomasTonho",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^24.0.0",
    "esbuild": "^0.28.1",
    "typescript": "^5.8.0"
  }
}
